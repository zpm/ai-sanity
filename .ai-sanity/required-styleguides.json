{
  "rules": [
    {
      "extension": ".py",
      "read": "./styleguides/python.md"
    },
    {
      "extension": [
        ".js",
        ".css",
        ".json"
      ],
      "read": "./styleguides/javascript.md"
    },
    {
      "extension": ".md",
      "read": "./styleguides/markdown.md"
    },
    {
      "extension": [
        ".sh",
        ".ps1"
      ],
      "read": "./styleguides/scripts.md"
    }
  ]
}
