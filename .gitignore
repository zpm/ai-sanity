# ignore everything by default
*

# allow repo metadata
!.gitignore
!.gitattributes

# allow synced config
!CLAUDE.md
!settings.json
!claude.code-workspace
!keybindings.json

# allow synced directories (and recurse into them)
!agents/
!agents/**
!commands/
!commands/**
!hooks/
!hooks/**
!plugins/
!plugins/**
!skills/
!skills/**
!styleguides/
!styleguides/**
!*.md

# python
__pycache__/
*.py[cod]
*$py.class
venv.*
