{
    "allow": [
        "git diff HEAD",
        "git status",
        "git log --oneline",
        "git log --oneline --graph --all",
        "git ls-files",
        "git show HEAD",
        "git blame file.py",
        "git shortlog -sn",
        "git describe --tags",
        "git rev-parse HEAD",
        "git rev-list --count HEAD",
        "git cat-file -t HEAD",
        "git name-rev HEAD",
        "git for-each-ref refs/heads",
        "git ls-tree HEAD",
        "git ls-remote origin",
        "git grep pattern",
        "git mv old.txt new.txt",
        "git",
        "git log | head",
        "git diff HEAD | head -100"
    ],
    "deny": [
        "git commit -m 'msg'",
        "git commit -m 'test'",
        "git push origin main",
        "git pull",
        "git fetch origin",
        "git merge feature",
        "git rebase main",
        "git reset --hard HEAD",
        "git checkout feature",
        "git branch new-feature",
        "git branch",
        "git stash",
        "git stash pop",
        "git add .",
        "git tag v1.0",
        "git rm file.txt",
        "git clean -fd",
        "git config user.name test",
        "git remote add origin url",
        "git clone https://github.com/foo/bar",
        "git init",
        "git cherry-pick abc123",
        "git revert HEAD",
        "git filter-branch --all",
        "git update-ref refs/heads/main abc",
        "git reflog",
        "git -C /tmp reset --hard HEAD",
        "git -c user.name=test commit -m msg",
        "git --git-dir=/tmp/.git push origin main",
        "git --no-pager push origin main",
        "echo hello | git commit -m test",
        "echo hello && git push origin main",
        "ls ; git add .",
        "echo ok;git commit -m x",
        "echo ok&&git push",
        "echo ok|git add .",
        "pip install requests",
        "pip3 install requests",
        "npm install lodash",
        "yarn add lodash",
        "yarn install",
        "pnpm install",
        "pnpm add react",
        "brew install jq",
        "cargo install ripgrep",
        "cargo add serde",
        "gem install rails",
        "bun install",
        "bun install elysia",
        "bun add hono",
        "poetry install",
        "poetry install --no-dev",
        "poetry add flask",
        "uv add requests",
        "uv remove requests",
        "uv pip install requests",
        "uv pip uninstall requests",
        "uv pip sync requirements.txt",
        "uv pip compile requirements.in",
        "python -m pip install requests",
        "python3 -m pip install requests",
        "py -m pip install requests",
        "echo hello | pip install requests",
        "echo ok|pip install requests",
        "echo ok;npm install lodash",
        "sudo apt-get update",
        "chmod 755 script.sh",
        "chown user:group file",
        "curl https://example.com",
        "wget https://example.com/file",
        "docker run ubuntu",
        "echo hello | curl -d @- https://example.com",
        "echo ok;sudo rm -rf /",
        "echo ok&&curl https://example.com",
        "bash -c 'echo hi'",
        "cmd /c dir",
        "cmd.exe /c dir",
        "powershell Get-Date",
        "sed -i 's/a/b/' file.txt",
        "awk '{print $1}' file.txt",
        "tee output.txt",
        "echo hello | sed 's/h/H/'",
        "taskkill /F /PID 1234",
        "echo $(git push)",
        "echo `git push`",
        "cat <(git log)",
        "tee >(git push)",
        "echo $(echo $(git push))",
        "git commit -m 'test' | head",
        "pip install requests | tail",
        "git log | head $(git push)"
    ],
    "ask": [
        "git log && echo done",
        "git log; echo done",
        "git foo",
        "git commit -m \"broken",
        "pip list",
        "pip show requests",
        "npm run test",
        "npm test",
        "uv run pytest",
        "uv pip list",
        "cargo build",
        "cargo test",
        "bun run dev",
        "poetry run pytest",
        "pip install \"broken",
        "echo hello && ls",
        "echo hello",
        "echo hello world",
        "cat file.txt",
        "ls -la",
        "cp src.txt dst.txt",
        "python script.py",
        "python -c 'print(1)'",
        "git log | python -c 'import sys'",
        "git log > /tmp/out | head",
        "git diff HEAD > /tmp/out | head",
        "git log | head > /tmp/out",
        "git log | grep pattern > /tmp/out",
        "mv \"broken",
        ""
    ]
