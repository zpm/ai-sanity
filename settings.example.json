{
  "permissions": {
    "allow": [
      "Read(~/Dev/ai-sanity/**)"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python $HOME/Dev/ai-sanity/hooks/instruction_repeater/userpromptsubmit.py"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python $HOME/Dev/ai-sanity/hooks/no_memory/pretooluse_write.py"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python $HOME/Dev/ai-sanity/hooks/no_memory/pretooluse_bash.py"
          },
          {
            "type": "command",
            "command": "python $HOME/Dev/ai-sanity/hooks/bash_playbook/pretooluse_bash.py"
          }
        ]
      },
      {
        "matcher": "Read|Glob|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "python $HOME/Dev/ai-sanity/hooks/no_memory/pretooluse_read.py"
          }
        ]
      },
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "python $HOME/Dev/ai-sanity/hooks/no_questions/pretooluse.py"
          }
        ]
      },
      {
        "matcher": "Write|Edit|NotebookEdit|Read",
        "hooks": [
          {
            "type": "command",
            "command": "python $HOME/Dev/ai-sanity/hooks/required_reading/pretooluse.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "python $HOME/Dev/ai-sanity/hooks/required_reading/posttooluse_observer.py"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python $HOME/Dev/ai-sanity/hooks/required_reading/precompact.py"
          },
          {
            "type": "command",
            "command": "python $HOME/Dev/ai-sanity/hooks/instruction_repeater/precompact.py"
          }
        ]
      }
    ]
  }
}
